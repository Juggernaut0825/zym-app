# Ralph generated files (inside .ralph/ subfolder)
.ralph/.call_count
.ralph/.last_reset
.ralph/.exit_signals
.ralph/status.json
.ralph/.ralph_session
.ralph/.ralph_session_history
.ralph/.claude_session_id
.ralph/.response_analysis
.ralph/.circuit_breaker_state
.ralph/.circuit_breaker_history

# Ralph logs and generated docs
.ralph/logs/*
!.ralph/logs/.gitkeep
.ralph/docs/generated/*
!.ralph/docs/generated/.gitkeep

# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/

# Node modules (if using Node.js projects)
node_modules/

# Python cache (if using Python projects)
__pycache__/
*.pyc

# Rust build (if using Rust projects)
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Ralph backup directories (created by migration)
.ralph_backup_*

# Environment files (never commit secrets)
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Build / runtime outputs
dist/
build/
coverage/
.next/
.run/
*.log

# Local agent/session artifacts
.ralph/
.ralphrc

# App runtime data
server/data/
server/skills/z/data/
server/skills/z/scripts/__pycache__/
web/.next/

# Dependencies
server/node_modules/
web/node_modules/
node_modules/

# iOS generated files
ios/ZYM.xcodeproj/xcuserdata/
ios/ZYM.xcodeproj/project.xcworkspace/xcuserdata/
ios/build/
DerivedData/

# Reference repo not part of app product
cats-company/
