{
  "name": "zym-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run rebuild:native",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "chroma:start": "mkdir -p ./data/chroma && chroma run --host 127.0.0.1 --port 8000 --path ./data/chroma",
    "db:export:sqlite": "tsx scripts/export-sqlite-to-postgres.ts",
    "db:generate:postgres-import": "tsx scripts/generate-postgres-import-sql.ts",
    "db:bootstrap:postgres": "./scripts/bootstrap-postgres-from-sqlite.sh",
    "kb:materialize": "tsx scripts/materialize-knowledge-manifest.ts",
    "kb:manifest": "node scripts/generate-knowledge-manifest.mjs",
    "kb:inspect": "tsx scripts/inspect-knowledge-corpus.ts",
    "kb:reindex": "tsx scripts/refresh-paper-corpus.ts --clear",
    "kb:reindex:partial": "tsx scripts/refresh-paper-corpus.ts --clear --allow-partial",
    "kb:papers": "tsx scripts/refresh-paper-corpus.ts",
    "media:backfill": "tsx scripts/backfill-media-assets.ts",
    "prestart": "npm run rebuild:native",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "start:scheduler": "node dist/scheduler.js",
    "rebuild:native": "npm rebuild better-sqlite3",
    "postinstall": "npm run rebuild:native"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@chroma-core/default-embed": "^0.1.9",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.71.0",
    "chalk": "^4.1.2",
    "chromadb": "^3.3.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.22.1",
    "google-auth-library": "^9.15.1",
    "heic-convert": "^2.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
