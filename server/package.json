{
  "name": "zym-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run rebuild:native",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "check:agent-security": "node scripts/agent-tool-boundary-check.mjs",
    "kb:manifest": "node scripts/generate-knowledge-manifest.mjs",
    "prestart": "npm run rebuild:native",
    "start": "node dist/index.js",
    "rebuild:native": "npm rebuild better-sqlite3",
    "postinstall": "npm run rebuild:native"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "chalk": "^4.1.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.22.1",
    "heic-convert": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.19.0",
    "sharp": "^0.34.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
