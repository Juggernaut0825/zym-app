# Base production example for a combined backend process.
# For the recommended ECS split deployment, use the role-specific examples:
# - server/.env.production.api.example
# - server/.env.production.ws.example
# - server/.env.production.worker.example
# - server/.env.production.scheduler.example

NODE_ENV=production
API_PORT=3001
WEBSOCKET_PORT=8080
ENABLE_API_SERVER=true
ENABLE_WEBSOCKET_SERVER=true
ENABLE_BACKGROUND_CLEANUP=true

OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_KEY=
JWT_SECRET=change-me
MEDIA_URL_SIGNING_SECRET=change-me

CORS_ALLOWED_ORIGINS=https://app.zym8.com,https://zym8.com,https://www.zym8.com
PUBLIC_BASE_URL=https://api.zym8.com
PUBLIC_MEDIA_BASE_URL=https://media.zym8.com
APP_WEB_BASE_URL=https://app.zym8.com
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
GOOGLE_IOS_REDIRECT_SCHEME=com.googleusercontent.apps.your-google-ios-client-id-prefix
APPLE_SERVICE_ID=your-apple-web-service-id
APPLE_IOS_APP_ID=com.zym8.app
ADMIN_DASHBOARD_USERNAME=admin
ADMIN_DASHBOARD_PASSWORD=change-me

EMAIL_DELIVERY_MODE=smtp
EMAIL_FROM=ZYM <no-reply@zym8.com>
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
# Brevo uses the SMTP login email and SMTP key shown
# in Transactional > SMTP settings.
SMTP_USER=your-smtp-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600

DATABASE_PROVIDER=postgres
APP_DATA_ROOT=/app/data
SQLITE_DATABASE_PATH=/app/data/zym.db
DATABASE_URL=postgres://zym_app:change-me@your-rds-endpoint:5432/zym
PGSSLMODE=require
DB_POOL_MAX=10

REDIS_URL=rediss://:your-auth-token@your-redis-endpoint:6379
REALTIME_BUS_PROVIDER=redis
REALTIME_REDIS_CHANNEL=zym:realtime
COACH_QUEUE_PROVIDER=bullmq
COACH_QUEUE_NAME=coach-replies
COACH_QUEUE_CONCURRENCY=4
COACH_QUEUE_WORKER_ENABLED=false
RATE_LIMIT_PROVIDER=redis
RATE_LIMIT_REDIS_PREFIX=zym:rate-limit

MEDIA_STORAGE_PROVIDER=s3
MEDIA_STORAGE_BUCKET=zym-private-media
MEDIA_PUBLIC_BUCKET=zym-public-media
MEDIA_STORAGE_REGION=us-east-2

CHROMA_URL=https://your-chroma-endpoint
KNOWLEDGE_ADMIN_IDS=1
