NODE_ENV=production
API_PORT=3001
WEBSOCKET_PORT=8080

OPENROUTER_API_KEY=
JWT_SECRET=change-me
MEDIA_URL_SIGNING_SECRET=change-me

CORS_ALLOWED_ORIGINS=https://app.zym8.com
PUBLIC_BASE_URL=https://api.zym8.com
PUBLIC_MEDIA_BASE_URL=https://media.zym8.com

# SQLite remains the active runtime in the current codebase.
DATABASE_PROVIDER=sqlite
SQLITE_DATABASE_PATH=/app/data/zym.db
DATABASE_URL=postgres://zym_app:change-me@your-rds-endpoint:5432/zym

REDIS_URL=rediss://:your-auth-token@your-redis-endpoint:6379
REALTIME_BUS_PROVIDER=redis
REALTIME_REDIS_CHANNEL=zym:realtime
COACH_QUEUE_PROVIDER=bullmq
COACH_QUEUE_NAME=coach-replies
COACH_QUEUE_CONCURRENCY=4
COACH_QUEUE_WORKER_ENABLED=false

MEDIA_STORAGE_PROVIDER=s3
MEDIA_STORAGE_BUCKET=zym-private-media
MEDIA_PUBLIC_BUCKET=zym-public-media
MEDIA_STORAGE_REGION=us-east-2

CHROMA_URL=https://your-chroma-endpoint
KNOWLEDGE_ADMIN_IDS=1
