# Required
OPENROUTER_API_KEY=

# Recommended for production
# JWT_SECRET=change-me-in-production

# Optional model override
GAUZ_LLM_MODEL=google/gemini-3-flash-preview
DEFAULT_USER_TIMEZONE=UTC

# Optional ports
WEBSOCKET_PORT=8080
API_PORT=3001
NODE_ENV=development

# Optional auth/session tuning
ACCESS_TOKEN_TTL_SECONDS=43200
SESSION_TTL_SECONDS=7776000
MAX_ACTIVE_SESSIONS_PER_USER=8
SESSION_CLEANUP_INTERVAL_SECONDS=900
SESSION_CLEANUP_INTERVAL_MINUTES=30
REVOKED_SESSION_RETENTION_DAYS=30

# Optional integrations
PINECONE_API_KEY=
PINECONE_INDEX_NAME=zym-knowledge
KB_ALLOWED_SOURCE_REGEX=
KNOWLEDGE_MANIFEST_MODE=optional
KNOWLEDGE_ADMIN_IDS=1
ANTHROPIC_API_KEY=
