# Required
OPENROUTER_API_KEY=

# Recommended for production
# JWT_SECRET=change-me-in-production

# Optional model override
GAUZ_LLM_MODEL=google/gemini-3-flash-preview
GAUZ_EMBEDDING_MODEL=qwen/qwen3-embedding-4b
DEFAULT_USER_TIMEZONE=UTC

# Optional ports
WEBSOCKET_PORT=8080
API_PORT=3001
NODE_ENV=development

# Optional auth/session tuning
ACCESS_TOKEN_TTL_SECONDS=43200
SESSION_TTL_SECONDS=7776000
MAX_ACTIVE_SESSIONS_PER_USER=8
SESSION_CLEANUP_INTERVAL_SECONDS=900
SESSION_CLEANUP_INTERVAL_MINUTES=30
REVOKED_SESSION_RETENTION_DAYS=30

# Optional integrations
MEDIA_STORAGE_PROVIDER=local
MEDIA_STORAGE_BUCKET=
MEDIA_PUBLIC_BUCKET=
PUBLIC_MEDIA_BASE_URL=
MEDIA_STORAGE_REGION=auto
MEDIA_STORAGE_ENDPOINT=
MEDIA_STORAGE_FORCE_PATH_STYLE=false
MEDIA_STORAGE_ACCESS_KEY_ID=
MEDIA_STORAGE_SECRET_ACCESS_KEY=
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_READ_URL_TTL_SECONDS=900
MEDIA_PENDING_UPLOAD_TTL_MINUTES=180
MEDIA_ORPHAN_FILE_TTL_HOURS=168
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION_NAME=zym-knowledge
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_AUTH_TOKEN=
KB_ALLOWED_SOURCE_REGEX=
KNOWLEDGE_MANIFEST_MODE=optional
KNOWLEDGE_ADMIN_IDS=1
ANTHROPIC_API_KEY=
