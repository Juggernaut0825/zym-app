# Production-like local / deployable runtime example.
# For the fastest local frontend/backend dev loop, copy `.env.development.example` instead.

# Required
OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_KEY=

# Recommended for production
# JWT_SECRET=change-me-in-production
# MEDIA_URL_SIGNING_SECRET=change-me-in-production

# Optional model override
GAUZ_LLM_MODEL=google/gemini-3-flash-preview
GAUZ_EMBEDDING_MODEL=qwen/qwen3-embedding-4b
DEFAULT_USER_TIMEZONE=UTC

# Optional ports
WEBSOCKET_PORT=8080
API_PORT=3001
NODE_ENV=development
ENABLE_API_SERVER=true
ENABLE_WEBSOCKET_SERVER=true
ENABLE_BACKGROUND_CLEANUP=true

# Database foundation
DATABASE_PROVIDER=postgres
APP_DATA_ROOT=data
SQLITE_DATABASE_PATH=data/zym.db
DATABASE_URL=postgres://zym:change-me@127.0.0.1:5432/zym
PGSSLMODE=disable
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=15000

# Optional auth/session tuning
ACCESS_TOKEN_TTL_SECONDS=43200
SESSION_TTL_SECONDS=7776000
MAX_ACTIVE_SESSIONS_PER_USER=8
SESSION_CLEANUP_INTERVAL_SECONDS=900
SESSION_CLEANUP_INTERVAL_MINUTES=30
REVOKED_SESSION_RETENTION_DAYS=30
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600

# Public app/origin settings
CORS_ALLOWED_ORIGINS=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3001
APP_WEB_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_IOS_REDIRECT_SCHEME=
ADMIN_DASHBOARD_USERNAME=admin
ADMIN_DASHBOARD_PASSWORD=

# Email delivery
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=ZYM <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Realtime / async foundation
# Leave these on local for single-process development, or point them at Redis for multi-instance deploys.
REDIS_URL=redis://127.0.0.1:6379
REALTIME_BUS_PROVIDER=local
REALTIME_REDIS_CHANNEL=zym:realtime
COACH_QUEUE_PROVIDER=local
COACH_QUEUE_NAME=coach-replies
COACH_QUEUE_CONCURRENCY=2
COACH_QUEUE_WORKER_ENABLED=true
RATE_LIMIT_PROVIDER=local
RATE_LIMIT_REDIS_PREFIX=zym:rate-limit

# Optional integrations
MEDIA_STORAGE_PROVIDER=local
MEDIA_STORAGE_BUCKET=
MEDIA_PUBLIC_BUCKET=
PUBLIC_MEDIA_BASE_URL=
MEDIA_STORAGE_REGION=auto
MEDIA_STORAGE_ENDPOINT=
MEDIA_STORAGE_FORCE_PATH_STYLE=false
MEDIA_STORAGE_ACCESS_KEY_ID=
MEDIA_STORAGE_SECRET_ACCESS_KEY=
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_READ_URL_TTL_SECONDS=900
MEDIA_PENDING_UPLOAD_TTL_MINUTES=180
MEDIA_ORPHAN_FILE_TTL_HOURS=168
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION_NAME=zym-knowledge
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_AUTH_TOKEN=
KB_ALLOWED_SOURCE_REGEX=
KNOWLEDGE_MANIFEST_MODE=optional
KNOWLEDGE_ADMIN_IDS=1
ANTHROPIC_API_KEY=

# iOS push notifications (APNs token auth)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.zym8.app
APNS_PRIVATE_KEY_PATH=
# Or use APNS_PRIVATE_KEY with escaped newlines instead of APNS_PRIVATE_KEY_PATH.
