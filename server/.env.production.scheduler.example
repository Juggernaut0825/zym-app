# Dedicated scheduler entrypoint:
# `node dist/scheduler.js`
# This entrypoint already starts the cleanup schedulers, so the flags below
# are informational and kept only to make the runtime role obvious.

NODE_ENV=production

ENABLE_API_SERVER=false
ENABLE_WEBSOCKET_SERVER=false
ENABLE_BACKGROUND_CLEANUP=true
COACH_QUEUE_WORKER_ENABLED=false

DATABASE_PROVIDER=postgres
APP_DATA_ROOT=/app/data
DATABASE_URL=postgres://zym_app:change-me@your-rds-endpoint:5432/zym
PGSSLMODE=require
DB_POOL_MAX=5

JWT_SECRET=change-me
MEDIA_URL_SIGNING_SECRET=change-me

PUBLIC_BASE_URL=https://api.zym8.com
PUBLIC_MEDIA_BASE_URL=https://media.zym8.com

MEDIA_STORAGE_PROVIDER=s3
MEDIA_STORAGE_BUCKET=zym-private-media
MEDIA_PUBLIC_BUCKET=zym-public-media
MEDIA_STORAGE_REGION=us-east-2
