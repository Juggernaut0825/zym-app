{
  "name": "zym-web",
  "version": "1.0.0",
  "scripts": {
    "clean": "node -e \"['.next','.next-prod'].forEach((dir)=>require('fs').rmSync(dir,{recursive:true,force:true}))\"",
    "predev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev",
    "build": "NEXT_DIST_DIR=.next-prod next build",
    "start": "NEXT_DIST_DIR=.next-prod node .next-prod/standalone/server.js"
  },
  "dependencies": {
    "next": "15.5.14",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3"
  }
}
